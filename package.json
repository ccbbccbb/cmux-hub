{
  "name": "cmux-hub",
  "version": "1.3.6",
  "private": true,
  "bin": {
    "cmux-hub": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/cli.ts -p 4567 --actions .claude/cmux-hub.json",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "build:compile": "bun run build-compile.ts",
    "test": "bun test src server",
    "lint": "oxlint .",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "bun run --bun tsc --noEmit",
    "test:e2e": "bunx playwright test e2e/smoke.spec.ts",
    "screenshots": "bunx playwright test e2e/screenshots.spec.ts",
    "version": "node -e \"const f='cmux-hub-plugin/.claude-plugin/plugin.json';const j=JSON.parse(require('fs').readFileSync(f));j.version=require('./package.json').version;require('fs').writeFileSync(f,JSON.stringify(j,null,2)+'\\n')\" && git add cmux-hub-plugin/.claude-plugin/plugin.json",
    "version:patch": "npm version patch && git push && git push --tags",
    "version:minor": "npm version minor && git push && git push --tags",
    "version:major": "npm version major && git push && git push --tags",
    "prepare": "git config --local core.hooksPath .githooks || echo 'Can not set git hooks'"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "react": "^19",
    "react-dom": "^19",
    "shiki": "^4.0.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "oxfmt": "0.36.0",
    "oxlint": "^1.51.0",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
